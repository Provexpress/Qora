generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  status      String        @default("Activo")
  description String?
  users       User[]
  leads       Lead[]
  services    ServiceItem[]
  spaces      Space[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
}

model Role {
  id    String @id @default(cuid())
  name  String @unique
  users User[]
}

model User {
  id            String        @id @default(cuid())
  name          String
  email         String        @unique
  password      String?
  roleId        String
  role          Role          @relation(fields: [roleId], references: [id])
  clientId      String?
  client        Client?       @relation(fields: [clientId], references: [id])
  leads         Lead[]
  opportunities Opportunity[]
  activities    Activity[]
  auditLogs     AuditLog[]
  timelineNotes Note[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([roleId])
  @@index([clientId])
}

model Lead {
  id             String        @id @default(cuid())
  fullName       String
  phone          String
  email          String
  source         String
  eventType      String
  estimatedDate  DateTime?
  peopleCount    Int
  status         String
  notes          String?
  clientId       String?
  client         Client?       @relation(fields: [clientId], references: [id])
  assignedUserId String?
  assignedUser   User?         @relation(fields: [assignedUserId], references: [id])
  opportunities  Opportunity[]
  timelineNotes  Note[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([assignedUserId])
  @@index([clientId])
  @@index([status])
  @@index([source])
  @@index([createdAt])
}

model Opportunity {
  id                String         @id @default(cuid())
  leadId            String
  lead              Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  title             String
  stageId           String
  stage             PipelineStage  @relation(fields: [stageId], references: [id])
  estimatedValue    Decimal        @default(0)
  priority          String
  expectedCloseDate DateTime?
  operationCode     String?        @unique
  wonAt             DateTime?
  closedAt          DateTime?
  operationalStatus String?
  notes             String?
  assignedUserId    String?
  assignedUser      User?          @relation(fields: [assignedUserId], references: [id])
  activities        Activity[]
  reservations      Reservation[]
  quotes            Quote[]
  purchaseTasks     PurchaseTask[]
  scheduleItems     EventScheduleItem[]
  cateringRequirements CateringRequirement[]
  timelineNotes   Note[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([leadId])
  @@index([stageId])
  @@index([assignedUserId])
  @@index([closedAt])
  @@index([wonAt])
}

model PipelineStage {
  id            String        @id @default(cuid())
  name          String        @unique
  order         Int
  color         String
  opportunities Opportunity[]
}

model Activity {
  id            String      @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  title         String
  description   String?
  activityDate  DateTime
  type          String
  status        String
  createdAt     DateTime    @default(now())

  @@index([opportunityId])
  @@index([userId])
  @@index([activityDate])
  @@index([status])
  @@index([type])
}

model Reservation {
  id              String      @id @default(cuid())
  opportunityId   String
  opportunity     Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  spaceId         String?
  space           Space?      @relation(fields: [spaceId], references: [id])
  reservationDate DateTime
  startTime       String
  endTime         String
  status          String
  notes           String?
  createdAt       DateTime    @default(now())

  @@index([opportunityId])
  @@index([spaceId])
  @@index([reservationDate])
  @@index([status])
}

model Quote {
  id            String      @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  quoteNumber   String      @unique
  title         String
  status        String
  subtotal      Decimal     @default(0)
  costSubtotal  Decimal     @default(0)
  discount      Decimal     @default(0)
  total         Decimal     @default(0)
  profit        Decimal     @default(0)
  marginPercent Decimal     @default(0)
  validUntil    DateTime
  notes         String?
  items         QuoteItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([opportunityId])
  @@index([status])
  @@index([createdAt])
}

model QuoteItem {
  id            String       @id @default(cuid())
  quoteId       String
  quote         Quote        @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  serviceItemId String?
  serviceItem   ServiceItem? @relation(fields: [serviceItemId], references: [id])
  description   String
  quantity      Int
  unitPrice     Decimal
  unitCost      Decimal     @default(0)
  total         Decimal
  totalCost     Decimal     @default(0)
  purchaseTasks PurchaseTask[]
  cateringRequirements CateringRequirement[]

  @@index([quoteId])
  @@index([serviceItemId])
}

model CateringRequirement {
  id            String      @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  quoteItemId   String?
  quoteItem     QuoteItem?   @relation(fields: [quoteItemId], references: [id], onDelete: SetNull)
  title         String
  category      String      @default("Alimentos")
  quantity      Int
  serviceTime   String?
  chefNotes     String?
  status        String      @default("Pendiente")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([opportunityId])
  @@index([quoteItemId])
}

model PurchaseTask {
  id            String      @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  quoteItemId   String?
  quoteItem     QuoteItem?   @relation(fields: [quoteItemId], references: [id])
  description   String
  category      String?
  quantity      Int
  estimatedCost Decimal     @default(0)
  supplier      String?
  status        String      @default("Pendiente")
  dueDate       DateTime?
  purchasedAt   DateTime?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([opportunityId])
  @@index([quoteItemId])
  @@index([status])
  @@index([dueDate])
}

model EventScheduleItem {
  id            String      @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  scheduleDate  DateTime?
  startTime     String
  endTime       String
  type          String
  owner         String?
  status        String      @default("Pendiente")
  order         Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([opportunityId])
  @@index([scheduleDate])
  @@index([status])
  @@index([order])
}

model ServiceItem {
  id          String      @id @default(cuid())
  clientId    String?
  client      Client?     @relation(fields: [clientId], references: [id])
  name        String
  category    String
  description String?
  price       Decimal
  cost        Decimal     @default(0)
  active      Boolean     @default(true)
  quoteItems  QuoteItem[]

  @@index([clientId])
  @@index([category])
  @@index([active])
}

model Space {
  id           String        @id @default(cuid())
  clientId     String?
  client       Client?       @relation(fields: [clientId], references: [id])
  name         String
  capacity     Int
  description  String?
  active       Boolean       @default(true)
  reservations Reservation[]

  @@index([clientId])
  @@index([active])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  entityType String
  entityId   String
  action     String
  summary    String
  metadata   String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model Note {
  id            String       @id @default(cuid())
  authorId      String
  author        User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  leadId        String?
  lead          Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  content       String
  visibility    String       @default("Interna")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([authorId])
  @@index([leadId])
  @@index([opportunityId])
  @@index([createdAt])
}
